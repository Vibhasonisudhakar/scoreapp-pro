PORT=5000
# Optional. If empty, app can still run with demo credentials.
MONGO_URI=

# Required in production. Use a long random value.
JWT_SECRET=replace_with_a_secure_random_secret

# Allow only your frontend URL in production, e.g. https://your-app.netlify.app
CORS_ORIGIN=*

# Demo credentials used when MongoDB is not connected.
DEMO_NAME=Demo User
DEMO_EMAIL=demo@scoreapp.com
DEMO_PASSWORD=Score123!

# Optional defaults for admin seed script.
ADMIN_NAME=ScoreApp Admin
ADMIN_EMAIL=admin@scoreapp.com
ADMIN_PASSWORD=Admin123!

# Set true only if you want forgot-password API to return reset token in response.
EXPOSE_RESET_TOKEN=true

# URL used to build reset links sent by email.
FRONTEND_URL=http://localhost:3000

# SMTP provider preset: custom | gmail | resend | sendgrid
EMAIL_PROVIDER=custom

# SMTP settings for forgot-password emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
RESET_FROM_EMAIL="ScoreApp <noreply@scoreapp.com>"

# Optional branding for reset emails.
RESET_BRAND_NAME=ScoreApp
RESET_SUPPORT_EMAIL=support@scoreapp.com

# --------------------------------------------------
# One-click SMTP templates (copy one provider block)
# --------------------------------------------------

# Gmail template
# EMAIL_PROVIDER=gmail
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_16_char_gmail_app_password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# RESET_FROM_EMAIL="ScoreApp <yourgmail@gmail.com>"

# Resend template
# EMAIL_PROVIDER=resend
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxx
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# RESET_FROM_EMAIL="ScoreApp <onboarding@resend.dev>"

# SendGrid template
# EMAIL_PROVIDER=sendgrid
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxx
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# RESET_FROM_EMAIL="ScoreApp <verified-sender@yourdomain.com>"
